{
  "name": "core",
  "version": "0.2.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --include . --clear-screen=false server.ts",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "NODE_ENV=test NODE_OPTIONS=\"--import tsx\" vitest run",
    "parse-report": "npx tsx scripts/parse-report.ts",
    "build:openapi": "npx tsx scripts/build-openapi.ts",
    "gen:nexudus": "npx swagger-typescript-api generate -p ./resources/nexudus-v1.json -o ./services/nexudus -n generated-api.ts --httpClient-type axios"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^9.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "swagger-typescript-api": "^13.6.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
